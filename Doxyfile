#---------------------------------------------------------------------------
# Project identity
#---------------------------------------------------------------------------

PROJECT_NAME           = "FitlyzerC"
PROJECT_BRIEF          = "Open-source FIT file analysis and visualization software"
PROJECT_NUMBER         =
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------

INPUT                  = src include docs .
RECURSIVE              = YES

FILE_PATTERNS          = *.cpp \
                         *.cxx \
                         *.cc \
                         *.hpp \
                         *.hxx \
                         *.hh \
                         *.h \
                         *.c \
                         *.md

EXCLUDE_PATTERNS       = */build/* \
                         */cmake-build-*/* \
                         */.git/* \
                         */.cache/* \
                         */CMakeFiles/*

EXCLUDE_SYMLINKS       = NO

#---------------------------------------------------------------------------
# Documentation extraction
#---------------------------------------------------------------------------

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = YES

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
INHERIT_DOCS           = YES

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO

#---------------------------------------------------------------------------
# Source browser
#---------------------------------------------------------------------------

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
VERBATIM_HEADERS       = YES

#---------------------------------------------------------------------------
# Markdown
#---------------------------------------------------------------------------

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 3

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_DYNAMIC_SECTIONS  = YES
FULL_SIDEBAR           = YES
DISABLE_INDEX          = NO
GENERATE_TREEVIEW      = YES

#---------------------------------------------------------------------------
# LaTeX/PDF output
#---------------------------------------------------------------------------

GENERATE_LATEX         = YES
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = YES
PDF_HYPERLINKS         = YES

#---------------------------------------------------------------------------
# Graphviz
#---------------------------------------------------------------------------

HAVE_DOT               = YES

CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
DIRECTORY_GRAPH        = YES

DOT_GRAPH_MAX_NODES    = 50
MAX_DOT_GRAPH_DEPTH    = 2

DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

#---------------------------------------------------------------------------
# C++ optimization
#---------------------------------------------------------------------------

OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO

#---------------------------------------------------------------------------
# Performance
#---------------------------------------------------------------------------

NUM_PROC_THREADS       = 0

#---------------------------------------------------------------------------
# Misc
#---------------------------------------------------------------------------

QUIET                  = NO
TAB_SIZE               = 4
CASE_SENSE_NAMES       = SYSTEM